# ════════════════════════════════════════════
#  WhatsApp API — Configuração
# ════════════════════════════════════════════

# ── Chaves de API (separadas por vírgula) ──
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
API_KEYS=coloque_sua_chave_aqui

# ── Debug ───────────────────────────────────
# true  → habilita /docs e /redoc (NÃO usar em produção)
# false → desabilita a documentação pública
DEBUG=false

# ── CORS ────────────────────────────────────
# * → permite qualquer origem
# Para restringir: http://zabbix.empresa.local,http://192.168.1.0
ALLOWED_ORIGINS=*

# ── Serviço WhatsApp interno ────────────────
# Não alterar se rodar via Docker Compose
WHATSAPP_SERVICE_URL=http://localhost:3000
WHATSAPP_SERVICE_TIMEOUT=30
